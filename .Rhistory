library(tidyverse)
theme_set(theme_minimal())
#devtools::install_github("ebabcock/PowerAfterChange")
library(PowerAfterChange) #Library with functions for power calculations after change
root <- rprojroot::find_package_root_file()
fish <- read_csv(file.path(root, "data", "Fish_only - Zero_counts_&_Env._data.csv"))
head(fish)
fishTotal<-fish %>%
group_by(Site, Season,WYR) %>%
summarise( Number = sum(num),
area_sampled=first(area_sampled)) %>%
ungroup() %>%
mutate(Density=Number/area_sampled,
Presence=if_else(Number>0,1,0),
logDensity=log(Density+0.00001))
ggplot(fishTotal, aes(x = factor(Site), y = logDensity,color=Season)) +
geom_boxplot() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1))+
labs(x = "Site", y = "Log Density (number/area)",
title = "Fish Density by Site and Season") +
scale_color_manual(values = c("DRY" = "blue", "WET" = "green")) +
theme(legend.position = "bottom")
fishTotal<-fish %>%
group_by(Site, Season,WYR) %>%
summarise( Number = sum(num),
area_sampled=first(area_sampled)) %>%
ungroup() %>%
mutate(Density=Number/area_sampled,
Presence=if_else(Number>0,1,0),
logDensity=log(Density+0.00001),
sqrtDensity=sqrt(Density+0.5))
fishSum<-summarize_baseline(fishTotal,
siteVar ="Site",
responseVar = "sqrtDensity",
groupVar = c("Season"),
logTransform = FALSE,
logAdd = 0.00001)
fishSum
sqrt(1.3)
sqrt(1.3)-sqrt(1)
sqr(0.3)
sqrt(0.3)
fishTotal %>%
group_by(Season, Site) %>%
summarise(n = n()) %>%
group_by(Season) %>%
summarise(mean_n = mean(n), min_n = min(n), max_n = max(n),
sqrtMean=mean(sqrtDensity))
fishTotal %>% group_by(Season) %>%
summarize(meanSqrt=mean(sqrtDensity))
fishTotal %>% group_by(Season) %>%
summarize(meanSqrt=mean(sqrtDensity),
meanSqrtPlus=mean(sqrtDensity*1.3))
fishTotal %>% group_by(Season) %>%
summarize(meanSqrt=mean(sqrtDensity),
meanSqrtPlus=mean(sqrtDensity*1.3))%>%
mutate(dif=meanSqrtPlus-meanSqrt,
percentChange=dif/meanSqrt*100)
fishTotal %>% group_by(Season) %>%
summarize(meanSqrt=mean(sqrtDensity),
meanSqrtPlus=mean(sqrtDensity*1.3))%>%
mutate(dif=meanSqrtPlus-meanSqrt,
percentChange=dif/meanSqrt*100)
