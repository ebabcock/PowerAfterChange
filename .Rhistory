TestSetup<-expand.grid(Variable=c("logDensity","Density","Number","Presence"),
PercentChange=c(10,20,30,40),
n_after=c(3,5,10),
delta_CV=c(0,0.1),
Season=c("WET","DRY")
)%>%
mutate(Distribution=case_when(Variable=="logDensity"~"normal",
Variable=="Density"~"normal",
Variable=="Number"~"nbinom",
Variable=="Presence"~"Binomial"),
Test=case_when(Variable=="logDensity"~"t.test",
Variable=="Density"~"t.test",
Variable=="Number"~"t.test",
Variable=="Presence"~"prop.test"),
sd_within=case_when(Variable=="logDensity"~fishSum$logsd_within[fishSum$Season==Season],
Variable=="Density"~fishSum$sd_within[fishSum$Season==Season],
Variable=="Number"~fishSum$sd_within[fishSum$Season==Season],
Variable=="Presence"~NA_real_),
baseline_mean=case_when(Variable=="logDensity"~mean(fishTotal$logDensity[fishTotal$Season==Season]),
Variable=="Density"~mean(fishTotal$Density[fishTotal$Season==Season]),
Variable=="Number"~mean(fishTotal$Number[fishTotal$Season==Season]),
Variable=="Presence"~mean(fishTotal$Presence[fishTotal$Season==Season])),
delta=case_when(Variable%in% c("logDensity","Density","Number")~log(1+PercentChange/100),
Variable=="Presence"~PercentChange/100),))
